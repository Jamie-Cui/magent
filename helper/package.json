{
  "name": "magent-happy-helper",
  "version": "0.1.0",
  "private": true,
  "description": "Happy bridge helper for Magent remote control",
  "type": "module",
  "bin": {
    "magent-happy-helper": "./dist/index.mjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "shx rm -rf dist && npx tsc --noEmit && pkgroll",
    "test": "vitest run"
  },
  "dependencies": {
    "@paralleldrive/cuid2": "^2.2.2",
    "@slopus/happy-wire": "^0.1.0",
    "axios": "^1.13.2",
    "socket.io-client": "^4.8.1",
    "tweetnacl": "^1.0.3",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": ">=20",
    "pkgroll": "^2.14.2",
    "shx": "^0.3.3",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "yarn@1.22.22"
}
